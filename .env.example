# Telegram Bot Kurulumu:
# 1. Telegram'da @BotFather'a mesaj at
# 2. /newbot komutunu gönder, isim ver
# 3. Sana bir BOT_TOKEN verecek — buraya yapıştır
# 4. Botuna /start yaz, sonra @userinfobot'a mesaj at → CHAT_ID'ni öğren

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Anomali eşikleri (isteğe bağlı, değiştirilebilir)
Z_SCORE_THRESHOLD=2.5
DAILY_RETURN_THRESHOLD=5.0
MARKET_CAP_CHANGE_THRESHOLD=10.0

# Veri çekme saati (her gün, TEFAS güncellendikten sonra)
FETCH_TIME=10:30

# Fon türü: YAT (Yatırım Fonu), EMK (Emeklilik), BYF (Borsa Yatırım Fonu)
FUND_TYPE=YAT
